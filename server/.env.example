# ===================================================
# EduQuest Server Configuration Template
# ===================================================

# Port to run the Express API server on
PORT=5000

# JSON Web Token Secret (Change this in production!)
JWT_SECRET=eduquest_secret_key_13579

# Groq API Key (Free tier LLM)
# Get a free key at: https://console.groq.com/
# Leave this blank to automatically fall back to the built-in "Mock AI" hints!
GROQ_API_KEY=

# PostgreSQL Database URL
# Example: postgresql://postgres:password@localhost:5432/eduquest
# Leave this blank to automatically fall back to a local SQLite database (eduquest.db)!
# DATABASE_URL=
